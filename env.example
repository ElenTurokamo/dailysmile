# Скопируй этот файл в .env и заполни значения

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API-ключ Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Время рассылки (HH:MM, часовой пояс контейнера/сервера)
SEND_TIME=06:00

# Поставь true, чтобы отправить предсказание сразу при запуске планировщика (для теста)
RUN_ON_START=false

# Модель (можно оставить по умолчанию)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
